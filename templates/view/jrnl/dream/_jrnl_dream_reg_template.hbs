<#--
 * 저널 꿈(jrnl_dream) > 등록/수정 Template
 * @included_in : _jrnl_dream_reg_modal.ftlh
-->

<script type="text/x-handlebars-template" id="jrnl_dream_reg_template">
    <#--begin::Row-->
    <div class="row">
        <div>
            <label class="mb-2">
                <span class="text-gray-700 fs-6 fw-bolder">태그</span>
                <span class="text-gray-500 fs-9 mx-2">※ 태그는 최대 15개, 50자까지 추가 가능합니다.</span>
            </label>
        </div>
        <div class="col-xl-12 text-sm-start" id="tagSpan">
            <input name="tag.tagListStr" id="tagListStr" class="form-control form-control-solid no-space" autocomplete="off" value="{{tag.tagListStrWithCtgr}}"/>
            <div class="d-flex pt-2 gap-2">
                <div id="tag_ctgr_select_div" style="display: none; position: relative;">
                    <select id="tag_ctgr_select" class="form-select orm-select-solid py-2">
                        <option value="custom">직접입력</option>
                    </select>
                </div>
                <div id="tag_ctgr_div" style="display:none;">
                    <input type="text" class="form-control form-control-sm form-control-solid w-200px" id="tag_ctgr" placeholder="태그 카테고리를 입력합니다.">
                </div>
            </div>
        </div>
    </div>
</script>