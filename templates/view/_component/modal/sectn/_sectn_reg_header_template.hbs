<#--
 * 단락(section) 등록/수정 헤더 Template
 * @included_in : 단락 기능이 있는 페이지들
 -->

<script type="text/x-handlebars-template" id="sectn_reg_header_template">
    <input type="hidden" name="postNo" value="{{postNo}}"/>
    <input type="hidden" name="refPostNo" value="{{refPostNo}}" />
    <input type="hidden" name="refContentType" value="{{refContentType}}" />
    <input type="hidden" name="actvtyCtgrCd" value="${actvtyCtgrCd!}" >

    <#--begin::Row-->
    <div class="row d-flex mb-8">
        <div class="col-12">
            <label class="d-flex align-items-center mb-2" for="title">
                <span class="text-gray-700 fs-6 fw-bolder">제목</span>
                <span class="text-gray-500 fs-9">(최대 50자)</span>
            </label>
        </div>
        <div class="col-lg-{{#if (exists postNo)}}11{{else}}12{{/if}}">
            <input type="text" class="form-control" name="title" id="title" maxlength="50" value="{{title}}" placeholder="제목" />
            <div id="title_valid_span"></div>
        </div>
        {{#if (exists postNo)}}
            {{^ifYn elseDreamYn}}
                <div class="col-1 d-flex ps-0">
                    <div class="d-flex-center p-2 fw-bold fs-5 text-gray-600">#</div>
                    <input type="number" class="form-control form-control-sm" name="idx" id="idx" min="1" max="99"
                           maxlength='2' value="{{idx}}" placeholder="인덱스"
                           data-bs-toggle="tooltip" data-bs-placement="top" title="일자 내에서의 정렬 인덱스입니다.">
                </div>
            {{/ifYn}}
        {{/if}}
    </div>
</script>