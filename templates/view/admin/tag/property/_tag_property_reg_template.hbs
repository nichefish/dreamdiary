<#--
 * 게시판 > 태그 상세 Template
 -->

<script type="text/x-handlebars-template" id="tag_admin_dtl_template">
    <!-- form start -->
    <input type="hidden" name="tagPropertyNo" id="tagPropertyNo" value="{{tagPropertyNo}}">

    <#--begin::Row-->
    <div class="row mb-4">
        <div class="col-2 text-center">
            <label for="menuNm" class="col-form-label fw-bold">
                CSS 클래스
            </label>
        </div>
        <div class="col-10 col-form-label">
            <div class="ps-2 text-gray-600 ls-1">
                <input type="text" name="cssClass" id="cssClass" class="form-control d-inline-block required"
                       value="{{cssClass}}" maxlength="200">
                <span id="cssClass_validate_span"></span>
            </div>
        </div>
    </div>
    <#--begin::Row-->
    <div class="row mb-4">
        <div class="col-2 text-center">
            <label for="menuNm" class="col-form-label fw-bold">
                CSS 스타일
            </label>
        </div>
        <div class="col-10 col-form-label">
            <div class="ps-2 text-gray-600 ls-1">
                <div class="ps-2 text-gray-600 ls-1">
                    <input type="text" name="cssStyle" id="cssStyle" class="form-control d-inline-block required"
                           value="{{cssStyle}}" maxlength="200">
                    <span id="cssStyle_validate_span"></span>
                </div>
            </div>
        </div>
    </div>
</script>